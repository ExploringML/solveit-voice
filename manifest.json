{
  "manifest_version": 3,
  "name": "SolveIt Voice",
  "version": "0.1",
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }],
  "permissions": ["storage"],
  "web_accessible_resources": [{
    "resources": ["ui.js", "voice.js"],
    "matches": ["<all_urls>"]
  }]
}
